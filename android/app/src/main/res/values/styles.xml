<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting. This theme is only displayed for the splash screen. -->
    <style name="LaunchTheme" parent="Theme.AppCompat.Light.NoActionBar">
        <!-- Show a splash screen on the activity. Automatically removed when the Flutter engine is ready. -->
        <item name="android:windowBackground">#FFFFFF</item>
    </style>
    <!-- Theme applied to the Android Window as soon as the Flutter UI is rendered. This theme is used for the regular activity. -->
    <style name="NormalTheme" parent="@android:style/Theme.Light.NoTitleBar">
        <item name="android:windowBackground">?android:colorBackground</item>
    </style>
</resources>
